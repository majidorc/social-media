generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AiProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
}

enum Platform {
  INSTAGRAM
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  FACEBOOK
}

enum WatermarkPosition {
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
  CENTER
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
  BANNED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  apiKeys           ApiKey[]
  contentWorkspaces ContentWorkspace[]
  settings          UserSettings?
  brandProfiles     BrandProfile[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultAiModel     String             @default("gpt-4o")
  plan                  Plan               @default(FREE)
  billingInterval       BillingInterval?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  planActivatedAt       DateTime?
  planExpiresAt         DateTime?
  watermarkLogoUrl      String?            @db.Text
  watermarkPosition     WatermarkPosition  @default(BOTTOM_RIGHT)
  companyName           String?
  businessDescription   String?            @db.Text
  websiteUrl            String?
  socialHandle          String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model BrandProfile {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  companyName         String?
  businessDescription String?  @db.Text
  websiteUrl          String?
  socialHandle        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model ApiKey {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     AiProvider
  encryptedKey String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, provider])
}

/// outputs JSON shape:
/// {
///   platforms: PlatformOutput[],
///   blendedPrompt: string,
///   modelUsed: string (provider-native model id),
///   visuals?: { imageUrl: string, promptUsed: string, imageModel: string },
///   video?: { url: string, script: string, voiceoverCopy: string }
/// }
model ContentWorkspace {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea       String?    @db.Text
  imageUrls  String[]   @default([])
  linkUrl    String?
  videoUrls  String[]   @default([])
  platforms  Platform[]
  aiModel    String
  imageModel String?
  enableVideo  Boolean   @default(false)
  scheduledFor DateTime?
  outputs      Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, scheduledFor])
}
