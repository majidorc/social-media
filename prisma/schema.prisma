generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AiProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
}

enum AiModel {
  GPT_4O
  GPT_4O_MINI
  CLAUDE_35_SONNET
  GEMINI_25_PRO
  GEMINI_25_FLASH
}

enum AiImageModel {
  IMAGEN_3_PRO
  IMAGEN_3_FAST
  DALL_E_3
}

enum Platform {
  INSTAGRAM
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  FACEBOOK
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  apiKeys           ApiKey[]
  contentWorkspaces ContentWorkspace[]
  settings          UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultAiModel AiModel  @default(GPT_4O)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ApiKey {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     AiProvider
  encryptedKey String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, provider])
}

/// outputs JSON shape:
/// {
///   platforms: PlatformOutput[],
///   blendedPrompt: string,
///   modelUsed: AiModel,
///   generatedAt: string,
///   visualImagePrompt?: string,
///   visuals?: { imageUrl: string, promptUsed: string, imageModel: AiImageModel }
/// }
model ContentWorkspace {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea       String?       @db.Text
  imageUrls  String[]      @default([])
  linkUrl    String?
  videoUrls  String[]      @default([])
  platforms  Platform[]
  aiModel    AiModel
  imageModel AiImageModel?
  outputs    Json          @default("{}")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}
